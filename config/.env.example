# EZ Internal Agent — Environment Variables
# Copy this to .env and fill in your values

# ── Ollama (local LLM on Mac Mini) ──
OLLAMA_URL=http://localhost:11434

# Primary model used by QA agent for code analysis & test generation
OLLAMA_MODEL=qwen2.5-coder:7b

# Research & market discovery model (used by research agent for reasoning)
OLLAMA_RESEARCH_MODEL=llama3.1:8b

# Lightweight edge model (fast inference for lead gen & simple tasks)
OLLAMA_EDGE_MODEL=llama3.2:3b

# ── GitHub Agent Bot ──
# Create a GitHub account (ez-agent-bot), give read access to all repos
GITHUB_AGENT_TOKEN=your_github_token_here

# ── EZ-Connect ──
EZCONNECT_URL=http://localhost:3002
EZCONNECT_API_KEY=your_ezconnect_api_key_here

# ── Discord ──
# Create a webhook in your Discord server (Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── Lead Gen ──
# Free at https://apify.com — 100 free runs/month
APIFY_TOKEN=your_apify_token_here

# ── Research Agent ──
# Free at https://serper.dev — 2500 free searches/month
SERPER_API_KEY=your_serper_api_key_here

# ── n8n ──
N8N_WEBHOOK_SECRET=your_n8n_secret_here

# ── Product Registry ──
REGISTRY_PATH=./config/products.json

# ── Agent Config ──
# Path where agent clones repos temporarily
REPOS_DIR=/tmp/ez-agent-repos
